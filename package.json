    "@types/heic-convert": "^2.1.0",
    "cheerio": "^1.0.0-rc.12",
    "cookie": "^1.0.2",
    "d3": "^7.9.0",
    "date-fns": "^4.1.0",
    "diff": "^9.0.0",
    "dragula": "^3.7.3",
    "drizzle-zero": "^0.18.0",
