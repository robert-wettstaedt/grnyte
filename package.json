{
  "name": "grnyte",
  "version": "0.0.1",
  "private": true,
  "homepage": "http://grnyte.rocks",
  "repository": {
    "type": "git",
    "url": "https://github.com/robert-wettstaedt/grnyte"
  },
  "engines": {
    "node": "^24.0.0"
  },
  "scripts": {
    "dev": "vite dev",
    "dev:zero": "npx zero-cache-dev",
    "build": "vite build",
    "prepare": "svelte-kit sync || echo ''",
    "preview": "vite preview",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "npx organize-imports-cli ./src && prettier --write .",
    "generate": "npm run generate:drizzle && npm run generate:zero",
    "migrate": "npx tsx src/lib/db/migrate.ts",
    "generate:drizzle": "drizzle-kit generate --config drizzle.config.ts",
    "generate:zero": "drizzle-zero generate --format --output src/lib/zero/zero-schema.gen.ts",
    "generate:pwa": "pwa-assets-generator",
    "machine-translate": "inlang machine translate --project project.inlang",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@keyv/postgres": "^2.0.4",
    "@lucide/svelte": "^1.17.0",
